# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/desksai

# Auth.js / NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# OpenRouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Encryption (generate with: openssl rand -base64 32)
ENCRYPTION_MASTER_KEY=

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@desksai.app

# Browserless (optional, for headless browser widget)
BROWSERLESS_TOKEN=
BROWSERLESS_URL=wss://chrome.browserless.io

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
